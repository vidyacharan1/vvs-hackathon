# Arogyam AI Backend Configuration
# Copy this file to .env and fill in your values.

APP_NAME=Arogyam AI
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# ── Database (Supabase) ──────────────────────────────────────────────
# 1. Create a free project at https://supabase.com
# 2. Go to Settings → Database → Connection string → URI
# 3. Copy the URI and replace [YOUR-PASSWORD] with your database password
# 4. Add ?sslmode=require to the end
#
# Format: postgresql+asyncpg://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/arogyam

# ── Redis (optional, for caching) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── AI ────────────────────────────────────────────────────
GEMINI_API_KEY=""

# ── Frontend ──────────────────────────────────────────────────────────
FRONTEND_ORIGIN=http://localhost:3000
